# Firebase config — copy this file to .env.local and fill in your values
# Get these from: Firebase Console → Project Settings → Your apps → Web app → SDK setup
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
VITE_BACKEND_URL=  # URL of your deployed backend, e.g. https://reverie-api.railway.app
