# ── WhatsApp Cloud API (Meta) ──────────────────────────────
# From Meta Developer Console → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=            # Permanent token (System User) or temp access token
WHATSAPP_PHONE_NUMBER_ID=  # e.g. 123456789012345
WHATSAPP_VERIFY_TOKEN=     # Any secret string you choose (e.g. "reverie-webhook-secret")
WHATSAPP_APP_SECRET=       # App Settings → Basic → App Secret

# ── OpenAI (Whisper transcription) ────────────────────────
OPENAI_API_KEY=            # sk-...

# ── Anthropic (Claude dream analysis) ─────────────────────
ANTHROPIC_API_KEY=         # sk-ant-...

# ── Firebase Admin (Firestore) ─────────────────────────────
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=       # e.g. reverie-12345
FIREBASE_CLIENT_EMAIL=     # e.g. firebase-adminsdk-xxxxx@reverie-12345.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=      # -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ── Server ─────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=https://your-app.vercel.app
