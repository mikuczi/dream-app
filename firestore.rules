rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────
    // Any signed-in user can READ profiles (needed for email lookup / circle invites).
    // Only the owner can WRITE their own profile.
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // ── Notifications & invitations ────────────────────────
    // Any signed-in user can CREATE notifications/invitations for any other user.
    // Only the recipient (owner) can update or delete their own.
    match /users/{uid}/notifications/{notifId} {
      allow read:   if request.auth.uid == uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == uid;
    }

    match /users/{uid}/invitations/{inviteId} {
      allow read:   if request.auth.uid == uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == uid;
    }

    // ── Circle documents (allow members to add themselves) ─
    // Any authenticated user can update a circle's memberIds
    // (used when accepting a circle invitation via arrayUnion).
    // Only the owner can create or delete their circles.
    match /users/{uid}/circles/{circleId} {
      allow read:   if request.auth.uid == uid;
      allow create, delete: if request.auth.uid == uid;
      allow update: if request.auth != null;
    }

    // ── User subcollections (dreams, chatHistory, etc.) ────
    // Only the owner can access their own subcollections.
    match /users/{uid}/{sub}/{docId} {
      allow read, write: if request.auth.uid == uid;
    }

    // ── Public / circle feed ───────────────────────────────
    // Any signed-in user can read feed posts.
    // Any signed-in user can write (create / update / delete) feed posts.
    match /feed/{postId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Feed subcollections (comments, likes) ──────────────
    match /feed/{postId}/{sub}/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── App config (whitelist, etc.) ───────────────────────
    // Signed-in users can read config. No client writes.
    match /config/{docId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

  }
}
